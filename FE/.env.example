# BFF Architecture - Backend For Frontend
# API Gateway: semua request frontend ke Express Backend di port 3000
VITE_API_URL=http://localhost:3000/api

# App Configuration
VITE_APP_NAME=Teman Pulih
VITE_APP_VERSION=1.0.0

# API Configuration
VITE_API_TIMEOUT=15000

# Feature Flags
VITE_ENABLE_DEBUG=false

# Authentication
VITE_TOKEN_STORAGE_KEY=token
